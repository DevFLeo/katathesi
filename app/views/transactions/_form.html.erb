<%= form_with(model: transaction, class: "contents") do |form| %>
  <% if transaction.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(transaction.errors.count, "error") %> prohibited this transaction from being saved:</h2>

      <ul class="list-disc ml-6">
        <% transaction.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.text_field :description, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": transaction.errors[:description].none?, "border-red-400 focus:outline-red-600": transaction.errors[:description].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :value %>
    <%= form.text_field :value, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": transaction.errors[:value].none?, "border-red-400 focus:outline-red-600": transaction.errors[:value].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :category %>
    <%= form.text_field :category, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": transaction.errors[:category].none?, "border-red-400 focus:outline-red-600": transaction.errors[:category].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :kind %>
    <%= form.number_field :kind, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": transaction.errors[:kind].none?, "border-red-400 focus:outline-red-600": transaction.errors[:kind].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :frequency %>
    <%= form.number_field :frequency, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": transaction.errors[:frequency].none?, "border-red-400 focus:outline-red-600": transaction.errors[:frequency].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :date %>
    <%= form.date_field :date, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": transaction.errors[:date].none?, "border-red-400 focus:outline-red-600": transaction.errors[:date].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :profit_margin %>
    <%= form.text_field :profit_margin, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": transaction.errors[:profit_margin].none?, "border-red-400 focus:outline-red-600": transaction.errors[:profit_margin].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
